<% content_for :title, "Welcome to Kaihai" %>

<div class="mx-auto w-full max-w-xl space-y-8">
  <header class="space-y-1">
    <h1 class="font-semibold text-2xl text-ink">Welcome.</h1>
    <p class="text-xs text-ink-soft italic">Two steps. Name your community, then give it an owner.</p>
  </header>

  <%= form_with url: setup_path, html: { class: "contents space-y-8" } do |form| %>
    <%= render "shared/ui/card", padding: :lg do %>
      <h2 class="text-lg font-semibold text-ink mb-1">Your community</h2>
      <p class="text-xs text-ink-soft italic mb-4">How this place introduces itself.</p>

      <%= fields_for :account, @account do |account_form| %>
        <%= render "shared/ui/input", form: account_form, field: :name, label: "Name", required: true, autofocus: true, placeholder: "Kaihai" %>
        <%= render "shared/ui/input", form: account_form, field: :tagline, label: "Tagline", placeholder: "a quiet community" %>
      <% end %>
    <% end %>

    <%= render "shared/ui/card", padding: :lg do %>
      <h2 class="text-lg font-semibold text-ink mb-1">Owner account</h2>
      <p class="text-xs text-ink-soft italic mb-4">The first admin. You can invite more people later.</p>

      <%= fields_for :user, @user do |user_form| %>
        <div data-controller="handle-suggest"
             data-handle-suggest-url-value="<%= users_handle_suggestion_path %>">
          <%= render "shared/ui/input", form: user_form, field: :name, label: "Name", required: true,
                     data: { handle_suggest_target: "name", action: "input->handle-suggest#nameInput" } %>
          <%= render "shared/ui/input", form: user_form, field: :handle, label: "Handle", required: true,
                     field_class: handle_field_classes,
                     data: { handle_suggest_target: "handle", action: "input->handle-suggest#handleEdited" } %>
          <p data-handle-suggest-target="hint" hidden class="-mt-3 mb-4 text-xs italic text-accent-yellow">
            That handle was taken — we picked a free one for you.
          </p>
        </div>
        <%= render "shared/ui/input", form: user_form, field: :email_address, label: "Email", type: "email", required: true, autocomplete: "email",
                   error: user_form.object.errors[:email_address].first %>
        <%= render "shared/ui/input", form: user_form, field: :password, label: "Password", type: "password", required: true, autocomplete: "new-password", maxlength: 72 %>
        <%= render "shared/ui/input", form: user_form, field: :password_confirmation, label: "Confirm password", type: "password", required: true, autocomplete: "new-password", maxlength: 72 %>
      <% end %>

      <div class="mt-6 flex justify-end">
        <%= render "shared/ui/button", label: "Begin", variant: :primary, type: "submit" %>
      </div>
    <% end %>
  <% end %>
</div>