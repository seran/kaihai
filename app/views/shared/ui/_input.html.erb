<%
  type          ||= "text"
  hint          ||= nil
  error         ||= nil
  icon_name       = local_assigns[:icon]
  icon_position ||= :leading
  field_class     = local_assigns[:field_class]
  attrs           = local_assigns.except(:form, :field, :label, :type, :hint, :error, :icon, :icon_position, :field_class)
  padding_class   = if icon_name && icon_position == :leading
                      "pl-9 pr-3"
                    elsif icon_name && icon_position == :trailing
                      "pl-3 pr-9"
                    else
                      "px-3"
                    end
%>
<div class="my-4">
  <%= form.label field, label, class: "block text-xs font-mono font-medium uppercase tracking-wider text-ink-faint mb-1.5" %>
  <div class="relative">
    <% if icon_name %>
      <span class="absolute inset-y-0 <%= icon_position == :leading ? 'left-0 pl-3' : 'right-0 pr-3' %> flex items-center text-ink-faint pointer-events-none">
        <%= icon(icon_name, size: 16) %>
      </span>
    <% end %>
    <%= form.send("#{type}_field",
                  field,
                  class: input_classes(error: error.present?, extra: "block w-full #{padding_class} #{field_class}".strip),
                  **attrs) %>
  </div>
  <% if hint && !error %>
    <p class="mt-1 text-xs text-ink-soft"><%= hint %></p>
  <% end %>
  <% if error %>
    <p class="mt-1 text-xs text-red-600"><%= error %></p>
  <% end %>
</div>
