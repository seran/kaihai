<% content_for :title, "Accept invitation" %>

<div class="mx-auto w-full max-w-md space-y-8">
  <header class="space-y-1">
    <h1 class="font-semibold text-2xl text-ink">Welcome.</h1>
    <p class="text-xs text-ink-soft italic">
      <% if @user.invited_by %>
        Invited by <%= @user.invited_by.name.presence || "@#{@user.invited_by.handle}" %>.
      <% else %>
        Set up your account to join <%= app_name %>.
      <% end %>
    </p>
  </header>

  <%= render "shared/ui/card", padding: :lg do %>
    <%= form_with model: @user, url: invitation_path(params[:token]), method: :patch, html: { class: "contents" } do |form| %>
      <div class="my-4">
        <span class="block text-xs font-mono font-medium uppercase tracking-wider text-ink-faint mb-1.5">Email</span>
        <div class="<%= input_classes(extra: 'block w-full px-3 cursor-not-allowed text-ink-soft') %>">
          <%= @user.email_address %>
        </div>
      </div>

      <div data-controller="handle-suggest"
           data-handle-suggest-url-value="<%= users_handle_suggestion_path(except_user_id: @user.id) %>">
        <%= render "shared/ui/input", form: form, field: :name, label: "Name", required: true,
                   data: { handle_suggest_target: "name", action: "input->handle-suggest#nameInput" } %>
        <%= render "shared/ui/input", form: form, field: :handle, label: "Handle", required: true,
                   field_class: handle_field_classes,
                   error: form.object.errors[:handle].first,
                   data: { handle_suggest_target: "handle", action: "input->handle-suggest#handleEdited" } %>
        <p data-handle-suggest-target="hint" hidden class="-mt-3 mb-4 text-xs italic text-accent-yellow">
          That handle isn't available — try another.
        </p>
      </div>

      <%= render "shared/ui/input", form: form, field: :password, label: "Password", type: "password",
                 required: true, autocomplete: "new-password", maxlength: 72,
                 error: form.object.errors[:password].first %>
      <%= render "shared/ui/input", form: form, field: :password_confirmation, label: "Confirm password", type: "password",
                 required: true, autocomplete: "new-password", maxlength: 72,
                 error: form.object.errors[:password_confirmation].first %>

      <div class="mt-6 flex justify-end">
        <%= render "shared/ui/button", label: "Begin", variant: :primary, type: "submit" %>
      </div>
    <% end %>
  <% end %>
</div>
