<% content_for :title, "Adminland · Edit @#{@user.handle}" %>
<% content_for :page_title, "Adminland" %>
<% content_for :page_subtitle, "Settings the rest of the community can't reach." %>

<div class="space-y-8">
  <%= render "admin/subnav" %>

  <turbo-frame id="admin-user" class="block space-y-8">
    <%= link_to admin_user_path(@user),
                data: { turbo_action: "advance" },
                class: "inline-flex items-center gap-1 text-xs font-mono uppercase tracking-wider text-ink-faint hover:text-ink transition-colors" do %>
      <%= icon "arrow-left", variant: :outline, size: 14 %>
      Back to @<%= @user.handle %>
    <% end %>

    <%# ── Profile ────────────────────────────────── %>
    <%= render "shared/ui/card", padding: :lg do %>
      <h2 class="text-lg font-semibold text-ink mb-1">Edit user</h2>
      <p class="text-xs text-ink-soft italic mb-4">Personal preferences (theme, accent, time zone) and password are user-only.</p>

      <%= form_with model: @user, url: admin_user_path(@user), method: :patch,
                    html: { class: "contents", data: { turbo_action: "advance" } } do |form| %>
        <%= render "shared/ui/input", form: form, field: :name, label: "Name", required: true %>
        <%= render "shared/ui/input", form: form, field: :email_address, label: "Email", type: "email", required: true,
                   error: form.object.errors[:email_address].first %>

        <%= render "shared/ui/radio_group", form: form, field: :role, label: "Role",
                   options: User.roles.keys.map { |r| [ r.titleize, r ] } %>

        <%= render "shared/ui/radio_group", form: form, field: :status, label: "Status",
                   options: User.statuses.keys.map { |s| [ s.titleize, s ] } %>

        <div class="mt-6 flex justify-end gap-2">
          <%= link_to "Cancel", admin_user_path(@user),
                      data: { turbo_action: "advance" },
                      class: button_classes(variant: :ghost) %>
          <%= render "shared/ui/button", label: "Save changes", variant: :primary, type: "submit" %>
        </div>
      <% end %>
    <% end %>

    <%# ── Handle ─────────────────────────────────── %>
    <%= render "shared/ui/card", padding: :lg do %>
      <h2 class="text-lg font-semibold text-ink mb-1">Handle</h2>
      <p class="text-xs text-ink-soft italic mb-4">The unique name appearing in URLs and mentions.</p>

      <%= form_with model: @user, url: admin_user_path(@user), method: :patch,
                    html: { class: "contents", data: { turbo_action: "advance" } } do |form| %>
        <div data-controller="handle-suggest"
             data-handle-suggest-url-value="<%= users_handle_suggestion_path(except_user_id: @user.id) %>">
          <%= render "shared/ui/input", form: form, field: :handle, label: "Handle", required: true,
                     field_class: handle_field_classes,
                     error: form.object.errors[:handle].first,
                     data: { handle_suggest_target: "handle", action: "input->handle-suggest#handleEdited" } %>
          <p data-handle-suggest-target="hint" hidden class="-mt-3 mb-4 text-xs italic text-accent-yellow">
            That handle isn't available — try another.
          </p>
        </div>
        <div class="mt-2 flex justify-end">
          <%= render "shared/ui/button", label: "Update handle", variant: :primary, type: "submit" %>
        </div>
      <% end %>
    <% end %>
  </turbo-frame>
</div>
