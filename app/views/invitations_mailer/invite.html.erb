<p>
  <% if @inviter %>
    <%= @inviter.name.presence || @inviter.handle %> invited you to join <%= Current.account&.name.presence || "Kaihai" %>.
  <% else %>
    You've been invited to join <%= Current.account&.name.presence || "Kaihai" %>.
  <% end %>
</p>

<p>
  <%= link_to "Set up your account", edit_invitation_url(@user.generate_token_for(:invitation)) %>
</p>

<p>This link expires in 24 hours.</p>
