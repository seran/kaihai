<% content_for :title, "Sign in with email" %>

<div class="mx-auto w-full max-w-md space-y-8">
  <header class="space-y-1">
    <h1 class="font-semibold text-2xl text-ink">Sign in with email.</h1>
    <p class="text-xs text-ink-soft italic">We'll send a one-time link.</p>
  </header>

  <%= render "shared/ui/card", padding: :lg do %>
    <%= form_with url: magic_links_path, html: { class: "contents" } do |form| %>
      <%= render "shared/ui/input", form: form, field: :email_address, label: "Email",
                 type: "email", required: true, autofocus: true, autocomplete: "username",
                 value: params[:email_address] %>

      <div class="mt-6 flex justify-end">
        <%= render "shared/ui/button", label: "Email me a sign-in link", variant: :primary, type: "submit" %>
      </div>
    <% end %>
  <% end %>

  <p class="text-center text-xs text-ink-soft">
    <%= link_to "Back to sign in", new_session_path, class: "text-accent hover:underline" %>
  </p>
</div>
