<% content_for :title, "Spaces" %>
<% content_for :page_title, "Spaces" %>
<% content_for :page_subtitle, "Discover and join the rooms inside Kaihai." %>

<%
  filters = [
    [ "all",        "All" ],
    [ "open",       "Open" ],
    [ "private",    "Private" ],
    [ "subscribed", "Subscribed" ],
    [ "favorites",  "Favorites" ]
  ]
%>

<turbo-frame id="spaces-list" class="block space-y-6">
  <div class="flex items-center justify-between gap-4 border-b border-line">
    <div role="tablist" class="flex gap-1 flex-wrap">
      <% filters.each do |key, label| %>
        <% active = @filter == key %>
        <%= link_to label, spaces_path(filter: key),
                    role: "tab",
                    data: { turbo_frame: "spaces-list", turbo_action: "advance" },
                    class: "px-5 py-2 -mb-px text-sm font-medium border-b-2 transition-colors cursor-pointer #{active ? 'border-accent text-accent' : 'border-transparent text-ink-soft hover:text-ink'}" %>
      <% end %>
    </div>
    <%= render "spaces/new_button" %>
  </div>

  <div id="spaces-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <% @spaces.each do |space| %>
      <%= render "spaces/card", space: space %>
    <% end %>
  </div>
  <% if @spaces.none? %>
    <%
      empty_messages = {
        "subscribed" => "You haven't joined any spaces yet.",
        "favorites"  => "No favorite spaces yet — tap a star to start.",
        "open"       => "No open spaces yet.",
        "private"    => "No private spaces yet."
      }
    %>
    <div id="spaces-empty">
      <%= render "shared/ui/card", padding: :lg do %>
        <p class="text-sm text-ink-soft italic">
          <%= empty_messages.fetch(@filter, "No spaces yet. Be the first to start one.") %>
        </p>
      <% end %>
    </div>
  <% end %>
</turbo-frame>
