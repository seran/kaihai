<%
  show_space = local_assigns.fetch(:show_space, true)
%>
<article class="border border-ink-soft/15 rounded-md p-4">
  <%# ── Header row ─────────────────────────────────── %>
  <div class="flex items-start gap-3">
    <div class="bg-accent-faint text-accent rounded-full w-9 h-9 flex items-center justify-center text-sm font-medium shrink-0">
      <%= user_initials(entry.author) %>
    </div>
    <div class="flex-1 min-w-0">
      <div class="text-ink truncate">
        <span class="font-medium"><%= entry.author.name.presence || entry.author.handle %></span>
        <% if show_space %>
          <span class="text-ink-soft">in</span>
          <%= link_to entry.space.name, space_path(entry.space),
                      data: { turbo_frame: "_top" },
                      class: "text-ink hover:text-accent transition-colors" %>
        <% end %>
      </div>
      <div class="text-xs text-ink-soft truncate">
        @<%= entry.author.handle %>
        <span class="text-ink-faint">·</span>
        <%= link_to space_entry_path(entry.space, entry),
                    data: { turbo_frame: "_top" },
                    class: "hover:text-accent transition-colors" do %>
          <time datetime="<%= entry.created_at.iso8601 %>" title="<%= l(entry.created_at, format: :long) %>">
            <%= time_ago_in_words(entry.created_at) %> ago
          </time>
        <% end %>
      </div>
    </div>
    <div class="shrink-0">
      <%= render "shared/ui/badge", label: entry.entryable_type.upcase, variant: :neutral %>
    </div>
  </div>

  <%# ── Content (full detail, matching entry show view) ── %>
  <div class="mt-5 space-y-3">
    <% case entry.entryable_type %>
    <% when "Post" %>
      <%= link_to space_entry_path(entry.space, entry),
                  data: { turbo_frame: "_top" },
                  class: "block hover:text-accent transition-colors" do %>
        <p class="text-ink whitespace-pre-line"><%= entry.entryable.body %></p>
      <% end %>

    <% when "Event" %>
      <% if entry.entryable.description.present? %>
        <p class="text-ink whitespace-pre-line"><%= entry.entryable.description %></p>
      <% end %>
      <%= render "spaces/entries/event_details", entry: entry, event: entry.entryable %>

    <% when "Poll" %>
      <% if entry.entryable.description.present? %>
        <p class="text-ink whitespace-pre-line"><%= entry.entryable.description %></p>
      <% end %>
      <%= render "spaces/entries/poll_details", entry: entry, poll: entry.entryable %>
    <% end %>
  </div>

  <%# ── Footer ───────────────────────────────────── %>
  <div class="mt-3 pt-3 border-t border-line flex items-center justify-between text-sm text-ink-soft">
    <div class="flex items-center gap-3">
      <%= render "spaces/entries/like_button", entry: entry %>
      <%= link_to space_entry_path(entry.space, entry),
                  data: { turbo_frame: "_top" },
                  class: "flex items-center gap-1 hover:text-accent transition-colors" do %>
        <%= icon "annotation", variant: :outline, size: 14 %>
        <%= entry.comments_count %>
      <% end %>
    </div>
    <%= render "spaces/entries/bookmark_button", entry: entry %>
  </div>

  <%# ── Latest comment preview ──────────────────── %>
  <% if entry.comments_count.to_i > 0 && (latest = entry.latest_comment) %>
    <div class="mt-3 pt-3 border-t border-line">
      <div class="flex items-start gap-2.5">
        <div class="bg-accent-faint text-accent rounded-full w-7 h-7 flex items-center justify-center text-xs font-medium shrink-0">
          <%= user_initials(latest.user) %>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-baseline gap-2 text-xs">
            <span class="font-medium text-ink truncate">@<%= latest.user.handle %></span>
            <time class="text-ink-faint shrink-0" datetime="<%= latest.created_at.iso8601 %>" title="<%= l(latest.created_at, format: :long) %>">
              <%= time_ago_in_words(latest.created_at) %> ago
            </time>
          </div>
          <p class="text-sm text-ink line-clamp-2 whitespace-pre-line mt-0.5"><%= latest.body %></p>
        </div>
      </div>
      <% if entry.comments_count > 1 %>
        <%= link_to space_entry_path(entry.space, entry),
                    data: { turbo_frame: "_top" },
                    class: "inline-block mt-2 text-xs text-ink-soft hover:text-accent transition-colors" do %>
          View all <%= entry.comments_count %> comments →
        <% end %>
      <% end %>
    </div>
  <% end %>
</article>